generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserState {
  userId           String   @id
  watchlistTickers String[]
  portfolio        Json
  alerts           Json     @default("[]")
  triggeredAlerts  Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
